{% extends 'base.html.twig' %}

{% block title %}Meal List{% endblock %}

{% block content %}
    <h1>Meal List</h1>

    {# ===== FILTER FORM ===== #}
    {#
    This form submits via GET method, so all parameters appear in URL
    Example: /meals/list?name=Pizza&excludeAllergens[]=1&sortBy=name&order=DESC

    method="get": Form data sent as URL parameters (not POST body)
    action: URL to submit to (generated by path() function)
    #}
    <form method="get" action="{{ path('data_meals_list') }}">

        {# --- SEARCH BY NAME --- #}
        <label>Suche nach Name:</label>
        {#
        Text input for searching meals by name
        value="{{ app.request.query.get('name') }}": Pre-fill with current search term

        app.request: Special Twig variable providing access to HTTP request
        .query.get('name'): Gets 'name' parameter from URL query string

        This preserves the search term when user filters or changes pages
        #}
        <input type="text" name="name" value="{{ app.request.query.get('name') }}">

        {# --- ALLERGEN EXCLUSION CHECKBOXES --- #}
        <fieldset>
            <legend>Allergene ausschließen:</legend>
            {#
            Loop through all allergens to create checkboxes

            Twig for loop syntax:
            {% for variable in collection %}
                ... use {{ variable }} ...
            {% endfor %}
            #}
            {% for allergen in allergens %}
                <label>
                    {#
                    Checkbox for each allergen
                    name="excludeAllergens[]": The [] makes it an array in PHP
                    value="{{ allergen.id }}": Submit allergen ID when checked

                    Ternary operator for 'checked' attribute:
                    {{ condition ? 'if_true' : 'if_false' }}

                    allergen.id in excludeAllergens: Checks if this allergen ID is in the array
                    If yes: add 'checked' attribute
                    If no: add empty string (no checked attribute)

                    This preserves checked state when user submits form
                    #}
                    <input type="checkbox" name="excludeAllergens[]" value="{{ allergen.id }}"
                        {{ allergen.id in excludeAllergens ? 'checked' : '' }}>
                    {# Display allergen code (e.g., "A", "C", "D") #}
                    {{ allergen.code }}
                </label>
            {% endfor %}
        </fieldset>

        {# --- SORT BY DROPDOWN --- #}
        <label>Sortieren nach:</label>
        <select name="sortBy">
            {#
            Option for sorting by name

            Conditional 'selected' attribute:
            app.request.query.get('sortBy') == 'name': Check if 'name' is currently selected
            ? 'selected' : '': If true, add 'selected' attribute, otherwise empty string

            This ensures the dropdown shows the current sort option
            #}
            <option value="name" {{ app.request.query.get('sortBy') == 'name' ? 'selected' : '' }}>Name</option>
            <option value="id" {{ app.request.query.get('sortBy') == 'id' ? 'selected' : '' }}>ID</option>
        </select>

        {# --- SORT ORDER DROPDOWN --- #}
        <select name="order">
            {# ASC = Ascending (A-Z, 1-10) #}
            <option value="ASC">Aufsteigend</option>
            {# DESC = Descending (Z-A, 10-1) #}
            <option value="DESC">Absteigend</option>
        </select>

        {# Submit button to apply filters #}
        <button type="submit">Filtern</button>
    </form>

    {# ===== MEALS TABLE ===== #}
    <table>
        <thead>
        <tr>
            <th>Name</th>
            <th>Allergene</th>
            <th>Nährwertinfo</th>
        </tr>
        </thead>
        <tbody>
        {#
        Loop through meals to display each one

        Special feature: {% else %} clause
        If the 'meals' collection is empty, the {% else %} block executes instead
        This provides a fallback message when no results are found
        #}
        {% for meal in meals %}
            <tr>
                {# Display meal name #}
                <td>{{ meal.name }}</td>

                <td>
                    {#
                    Nested loop: Display all allergens for this meal
                    Each allergen code is wrapped in a <span class="badge">
                    #}
                    {% for allergen in meal.allergens %}
                        <span class="badge">{{ allergen.code }}</span>
                    {% endfor %}
                </td>

                {# Display nutritional information #}
                <td>{{ meal.nutritionalInfo }}</td>
            </tr>
        {% else %}
            {#
            FALLBACK: This executes if 'meals' is empty
            colspan="3": Makes this cell span all 3 columns
            #}
            <tr>
                <td colspan="3">Keine Meals gefunden.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    {# ===== PAGINATION ===== #}
    {# Only show pagination if there's more than 1 page #}
    {% if totalPages > 1 %}
        <nav>
            {#
            Loop through page numbers: 1 to totalPages

            Syntax: {% for variable in start..end %}
            Example: If totalPages = 5, this creates: 1, 2, 3, 4, 5
            #}
            {% for p in 1..totalPages %}
                {#
                Create link for each page number

                path() function: Generates URL for a named route
                First parameter: Route name ('data_meals_list')
                Second parameter: URL parameters (object/array)

                app.request.query.all: Gets ALL current URL parameters
                |merge({page: p}): MERGE filter adds/overwrites 'page' parameter

                Example result:
                Current URL: /meals/list?name=Pizza&sortBy=name
                Page 2 link: /meals/list?name=Pizza&sortBy=name&page=2

                This preserves all filters when changing pages!

                class attribute uses ternary operator:
                p == currentPage: If this is the current page
                ? 'active' : '': Add 'active' class, otherwise no class

                The 'active' class can be styled with CSS to highlight current page
                #}
                <a href="{{ path('data_meals_list', app.request.query.all|merge({page: p})) }}"
                   class="{{ p == currentPage ? 'active' : '' }}">{{ p }}</a>
            {% endfor %}
        </nav>
    {% endif %}
{% endblock %}
