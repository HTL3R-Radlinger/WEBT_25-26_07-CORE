{% extends 'base.html.twig' %}

{% block title %}Delete Meal{% endblock %}

{% block content %}
    <h1>Delete Meal</h1>

    <table class="table">
        <thead>
        <tr>
            <th>Name</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        {% for meal in meals %}
            <tr>
                <td>{{ meal.name }}</td>
                <td>
                    <form method="post" action="{{ path('meal_delete_by_id', {'id': meal.id}) }}"
                          onsubmit="return confirm('Are you sure you want to delete this meal?');">
                        <button class="btn btn-danger btn-sm">Delete</button>
                    </form>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

{% endblock %}
